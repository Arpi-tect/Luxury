// Prisma Schema for Luxury — Premium Hotel Reservation System

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  passwordHash  String
  loyaltyTier   String         @default("Silver") // Silver, Gold, Platinum
  loyaltyPoints Int            @default(0)
  bookings      Booking[]
  reviews       Review[]
  agentSessions AgentSession[]
  createdAt     DateTime       @default(now())
}

model Hotel {
  id          String   @id @default(uuid())
  name        String   @default("Luxury Palace")
  location    String
  description String
  images      String[]
  rooms       Room[]
}

model Room {
  id            String    @id @default(uuid())
  hotelId       String
  hotel         Hotel     @relation(fields: [hotelId], references: [id])
  roomNumber    Int       @unique
  category      String    // Standard, Deluxe, Suite
  pricePerNight Float
  amenities     String[]
  images        String[]
  capacity      Int
  available     Boolean   @default(true)
  bookings      Booking[]
  reviews       Review[]
}

model Booking {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  roomId        String
  room          Room      @relation(fields: [roomId], references: [id])
  checkIn       DateTime
  checkOut      DateTime
  guests        Int
  breakfast     Boolean   @default(false)
  shuttle       Boolean   @default(false)
  spa           Boolean   @default(false)
  promoCode     String?
  discount      Float     @default(0.0)
  totalPrice    Float
  status        String    @default("PENDING") // PENDING, PAID, CANCELLED
  qrCode        String?
  payments      Payment[]
  createdAt     DateTime  @default(now())
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id])
  rating    Int
  comment   String
  createdAt DateTime @default(now())
}

model Promotion {
  id              String   @id @default(uuid())
  code            String   @unique
  discountPercent Float
  validFrom       DateTime
  validTo         DateTime
}

model Payment {
  id            String   @id @default(uuid())
  bookingId     String
  booking       Booking  @relation(fields: [bookingId], references: [id])
  provider      String   @default("stripe") // stripe, razorpay
  status        String   // SUCCESS, FAILED, REFUNDED
  amount        Float
  transactionId String   @unique
  createdAt     DateTime @default(now())
}

model Embedding {
  id         String   @id @default(uuid())
  sourceType String   // room, policy, faq, guide
  sourceId   String
  content    String
  vector     Unsupported("vector(1536)") // pgvector extension for embedding vectors
  metadata   Json
  createdAt  DateTime @default(now())
}

model AgentSession {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  sessionMemory Json     // JSON representation of agent states
  lastIntent    String?
  createdAt     DateTime @default(now())
}
